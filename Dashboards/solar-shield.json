                      "spec": {
                        "query": "from(bucket: \"solar_shield_telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"inverter_telemetry\")\n  |> filter(fn: (r) => r[\"_field\"] == \"mse\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"Reconstruction Error\")"
